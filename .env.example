# ============================================
# Qwen2API Configuration
# ============================================

# API Key(s) - comma separated, first key is admin key
# Required for authentication
API_KEY=sk-your-api-key-here

# Qwen Account(s) - format: email1:password1,email2:password2
# Required for accessing Qwen AI
ACCOUNTS=your-email@example.com:your-password

# Optional: comma-separated emails to disable at startup. Disabled
# accounts stay loaded (so you can re-enable from the admin UI without
# re-entering the password) but the rotator skips them. The admin
# endpoint POST /api/disableAccount toggles this at runtime; on Vercel
# / Netlify the helper writes the updated list back here so it
# survives cold starts.
# DISABLED_ACCOUNTS=disabled1@example.com,disabled2@example.com

# ============================================
# Server Configuration
# ============================================

# Service port (default: 3000)
SERVICE_PORT=3000

# Listen address (default: all interfaces)
# LISTEN_ADDRESS=0.0.0.0

# Number of worker processes (default: 1, use 'max' for all CPU cores)
# PM2_INSTANCES=1

# ============================================
# Data Persistence
# ============================================

# Data save mode: none | file | redis
# none  = env vars only, no filesystem (no persistence; tokens / proxy
#         state / runtime API keys / usage all reset on restart)
# file  = save to data/data.json — REQUIRES A PERSISTENT DISK
#         ⚠ Vercel / Netlify / Cloudflare Workers DO NOT have persistent
#         disk; use `redis` there instead.
# redis = Redis-over-HTTP (Upstash REST protocol). Ideal for serverless.
#
# ── Docker / docker-compose users: LEAVE THIS COMMENTED OUT. ──
# docker-compose.yml hard-codes DATA_SAVE_MODE=file so the ./data
# volume actually gets written. If you uncomment + override here,
# compose will NOT pick it up (the value in compose is hard-coded,
# not interpolated). Edit docker-compose.yml directly if you want
# something other than file mode for Docker.
#
# ── Bare-metal / npm-start users: pick the right value for you. ──
# DATA_SAVE_MODE=none

# Redis credentials (only when DATA_SAVE_MODE=redis). The client looks
# up env vars in this priority order, so most providers Just Work:
#
#   1. REDIS_URL           + REDIS_TOKEN            ← generic, recommended
#   2. KV_REST_API_URL     + KV_REST_API_TOKEN      ← Vercel KV (auto-injected when the integration is attached)
#   3. UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN ← Upstash console "REST API" tab
#
# Pick whichever pair matches your provider; you only need one.
# REDIS_URL=https://xxxxx.upstash.io
# REDIS_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Feature Configuration
# ============================================

# Output thinking content (default: false)
# OUTPUT_THINK=false

# Search info display mode: text | table (default: text)
# SEARCH_INFO_MODE=text

# Simple model map - only show base models without suffixes (default: false)
# SIMPLE_MODEL_MAP=false

# ============================================
# Logging
# ============================================

# Log level: DEBUG | INFO | WARN | ERROR (default: INFO)
LOG_LEVEL=INFO

# Enable file logging (default: false)
# ENABLE_FILE_LOG=false

# Log directory (default: ./logs)
# LOG_DIR=./logs

# Max log file size in MB (default: 10)
# MAX_LOG_FILE_SIZE=10

# Max number of log files to keep (default: 5)
# MAX_LOG_FILES=5

# ============================================
# Proxy Configuration
# ============================================

# Smart proxy pool — comma-separated list. Schemes: socks5, socks4,
# http, https. Each account is bound to one proxy with state persistence,
# four-tier priority (exclusive > untested > recovered > shared), and
# automatic failover (up to PROXY_MAX_RETRIES attempts) when a request
# fails with a network-level error.
#   PROXIES=socks5://1.2.3.4:1080,http://user:pass@5.6.7.8:8080

# Legacy single-proxy form (still supported, merged into the pool).
# PROXY_URL=http://127.0.0.1:7890

# Maximum retries on proxy-shaped network errors (default: 3)
# PROXY_MAX_RETRIES=3

# ============================================
# Custom Reverse Proxy
# ============================================

# Custom Qwen Chat API base URL (default: https://chat.qwen.ai)
# QWEN_CHAT_PROXY_URL=https://chat.qwen.ai

# ============================================
# Chat ID Warmup Pool
# ============================================

# Pre-creates chat_ids in the background so requests after idle don't
# suffer cold-start latency (500ms–6s) on /api/v2/chats/new. The pool
# keeps each account "warm" with ready-to-use chat sessions.
# Only active in non-serverless mode (Docker / bare-metal).

# Number of pre-warmed chat_ids per account (default: 3)
# CHAT_POOL_SIZE_PER_ACCOUNT=3

# Chat_id time-to-live in seconds; expired ones are discarded & rebuilt (default: 600 = 10min)
# CHAT_POOL_TTL_SECONDS=600

# How often (seconds) the background loop checks & refills the pool (default: 30)
# CHAT_POOL_REFILL_INTERVAL=30

# Model used when pre-creating chat sessions (default: qwen3-235b-a22b)
# CHAT_POOL_DEFAULT_MODEL=qwen3-235b-a22b

# ============================================
# Vercel 同步（可选，仅 Vercel 部署时需要）
# ============================================

# Vercel API Token（https://vercel.com/account/tokens 创建）
# VERCEL_TOKEN=

# Vercel 项目 ID（项目 Settings → General）
# VERCEL_PROJECT_ID=

# Vercel 团队 ID（个人账号留空）
# VERCEL_TEAM_ID=
